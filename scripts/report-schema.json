{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RepoAuditResult",
  "description": "Output schema all audit agents must produce",
  "type": "object",
  "required": [
    "auditId",
    "repoFullName",
    "status",
    "startedAt",
    "summary",
    "results"
  ],
  "properties": {
    "auditId": { "type": "string", "format": "uuid" },
    "repoFullName": { "type": "string", "example": "owner/repo" },
    "status": { "type": "string", "enum": ["running", "complete", "error"] },
    "startedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp with time component (not midnight placeholder). Capture with: date -u +\"%Y-%m-%dT%H:%M:%SZ\"",
      "example": "2026-04-20T14:23:15Z"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp with time component (not midnight placeholder). Capture with: date -u +\"%Y-%m-%dT%H:%M:%SZ\"",
      "example": "2026-04-20T14:45:32Z"
    },
    "agentTool": {
      "type": "string",
      "enum": ["claude", "codex", "copilot"],
      "description": "Which AI tool ran this audit"
    },
    "summary": {
      "type": "object",
      "required": [
        "overallScore",
        "totalFindings",
        "bySeverity",
        "byCategory",
        "riskLevel"
      ],
      "properties": {
        "overallScore": { "type": "integer", "minimum": 0, "maximum": 100 },
        "totalFindings": { "type": "integer", "minimum": 0 },
        "riskLevel": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "clean"]
        },
        "bySeverity": {
          "type": "object",
          "properties": {
            "critical": { "type": "integer" },
            "high": { "type": "integer" },
            "medium": { "type": "integer" },
            "low": { "type": "integer" },
            "info": { "type": "integer" }
          }
        },
        "byCategory": {
          "type": "object",
          "properties": {
            "security": { "type": "integer" },
            "quality": { "type": "integer" },
            "api": { "type": "integer" },
            "db": { "type": "integer" },
            "npm": { "type": "integer" },
            "npq": { "type": "integer" }
          }
        },
        "baselineComparison": {
          "type": "object",
          "description": "Phase 1.1 - Baseline suppression results",
          "properties": {
            "previousAuditFound": { "type": "boolean" },
            "previousAuditId": { "type": "string" },
            "newFindings": { "type": "integer" },
            "existingFindings": { "type": "integer" }
          },
          "required": ["previousAuditFound", "newFindings", "existingFindings"]
        },
        "autoFixSuggestions": {
          "type": "object",
          "description": "Phase 1.2 - Auto-fix suggestions results",
          "properties": {
            "totalFixable": { "type": "integer" },
            "generated": { "type": "boolean" }
          },
          "required": ["totalFixable", "generated"]
        },
        "contextAwareSeverity": {
          "type": "object",
          "description": "Phase 1.3 - Context-aware severity adjustments",
          "properties": {
            "adjustmentsApplied": { "type": "integer" },
            "adjustments": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "file": { "type": "string" },
                  "rule": { "type": "string" },
                  "from": { "type": "string" },
                  "to": { "type": "string" }
                }
              }
            },
            "totalAdjustments": { "type": "integer" }
          },
          "required": ["adjustmentsApplied", "totalAdjustments"]
        },
        "crossToolDeduplication": {
          "type": "object",
          "description": "Phase 1.4 - Cross-tool deduplication results",
          "properties": {
            "originalFindings": { "type": "integer" },
            "mergedFindings": { "type": "integer" },
            "reductionCount": { "type": "integer" },
            "mergeOperations": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "file": { "type": "string" },
                  "line": { "type": "integer" },
                  "primarySource": { "type": "string" },
                  "secondarySource": { "type": "string" },
                  "similarity": { "type": "integer" }
                }
              }
            },
            "totalMergeOperations": { "type": "integer" }
          },
          "required": ["originalFindings", "mergedFindings", "reductionCount", "totalMergeOperations"]
        }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "status", "score", "findings"],
        "properties": {
          "category": {
            "type": "string",
            "enum": ["security", "quality", "api", "db", "npm", "npq"]
          },
          "status": { "type": "string", "enum": ["passed", "failed", "error"] },
          "score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "durationMs": { "type": "integer" },
          "timestamp": { "type": "string", "format": "date-time" },
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "category",
                "severity",
                "title",
                "description",
                "source"
              ],
              "properties": {
                "id": { "type": "string" },
                "category": {
                  "type": "string",
                  "enum": ["security", "quality", "api", "db", "npm", "npq"]
                },
                "severity": {
                  "type": "string",
                  "enum": ["critical", "high", "medium", "low", "info"]
                },
                "title": { "type": "string" },
                "description": { "type": "string" },
                "file": { "type": "string" },
                "line": { "type": "integer" },
                "rule": { "type": "string" },
                "cwe": { "type": "string", "pattern": "^CWE-[0-9]+$" },
                "fix": { "type": "string" },
                "source": {
                  "type": "string",
                  "description": "Primary detection source, or combined sources for deduplicated findings"
                },
                "sources": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "npm-audit",
                      "npq", 
                      "gitleaks",
                      "semgrep",
                      "ai",
                      "eslint",
                      "static",
                      "depcheck",
                      "tsc",
                      "git"
                    ]
                  },
                  "description": "Phase 1.4 - All sources that detected this finding"
                },
                "status": {
                  "type": "string",
                  "enum": ["new", "existing"],
                  "description": "Phase 1.1 - Baseline suppression status"
                },
                "autofix": {
                  "type": "object",
                  "description": "Phase 1.2 - Auto-fix suggestion",
                  "properties": {
                    "type": { "type": "string", "enum": ["diff", "command"] },
                    "description": { "type": "string" },
                    "patch": { "type": "string" },
                    "command": { "type": "string" },
                    "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
                  },
                  "required": ["type", "description"]
                },
                "severityAdjusted": {
                  "type": "object",
                  "description": "Phase 1.3 - Context-aware severity adjustment details",
                  "properties": {
                    "originalSeverity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
                    "adjustedSeverity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
                    "rule": { "type": "string" },
                    "reason": { "type": "string" }
                  },
                  "required": ["originalSeverity", "adjustedSeverity", "rule", "reason"]
                },
                "deduplicated": {
                  "type": "object",
                  "description": "Phase 1.4 - Cross-tool deduplication details",
                  "properties": {
                    "mergedFrom": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "source": { "type": "string" },
                          "id": { "type": "string" },
                          "severity": { "type": "string" },
                          "title": { "type": "string" }
                        }
                      }
                    },
                    "mergedAt": { "type": "string", "format": "date-time" }
                  },
                  "required": ["mergedFrom", "mergedAt"]
                }
              }
            }
          }
        }
      }
    },
    "contributors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "name": { "type": "string" },
          "commits": { "type": "integer" },
          "additions": { "type": "integer" },
          "deletions": { "type": "integer" },
          "firstCommitAt": { "type": "string", "format": "date-time" },
          "lastCommitAt": { "type": "string", "format": "date-time" },
          "isBot": { "type": "boolean" }
        }
      }
    },
    "commitTimeline": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "week": { "type": "string", "pattern": "^[0-9]{4}-W[0-9]{2}$" },
          "commits": { "type": "integer" }
        }
      }
    }
  }
}
