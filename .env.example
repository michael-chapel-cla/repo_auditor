# Comma-separated list of GitHub repos to audit (owner/repo format)
GITHUB_REPOS=owner/repo1,owner/repo2

# npm token — required if the target repo uses a private npm registry (e.g. Azure Artifacts)
# Used by `npm audit` and the S14 package safety check. Leave blank for public registries.
NPM_TOKEN=your_npm_token_here

# Anthropic API key for AI-powered code scanning
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Directory where cloned repos will be checked out (relative to project root)
WORKSPACE_DIR=./workspace

# Directory where audit reports will be written (relative to project root)
REPORTS_DIR=./reports

# API server port
API_PORT=4000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# npm token — required if the target repo uses a private registry (e.g. Azure Artifacts)
# The token is passed as NPM_TOKEN to `npm audit`. Without it, npm audit returns 401
# and the npm category will contain a skipped-audit info finding instead of real results.
# NPM_TOKEN=your_azure_artifacts_base64_token_here
