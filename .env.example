# Comma-separated list of GitHub repos to audit (owner/repo format)
GITHUB_REPOS=owner/repo1,owner/repo2

# GitHub personal access token (needs repo read scope for contributor stats)
GITHUB_TOKEN=ghp_your_token_here

# Anthropic API key for AI-powered code scanning
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Directory where cloned repos will be checked out (relative to project root)
WORKSPACE_DIR=./workspace

# Directory where audit reports will be written (relative to project root)
REPORTS_DIR=./reports

# API server port
API_PORT=4000

# Log level: debug | info | warn | error
LOG_LEVEL=info
